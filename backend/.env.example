# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/webamazee_lms?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_too_to_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer SMTP - e.g. Gmail App Password, Zoho, SendGrid SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Webamazee <no-reply@webamazee.com>"

# Scraper
SCRAPER_HEADLESS=true
SCRAPER_MAX_CONCURRENT_JOBS=2
SCRAPER_NAV_TIMEOUT_MS=45000

# First tenant bootstrap (used only by seed script)
SEED_COMPANY_NAME=Webamazee
SEED_COMPANY_SLUG=webamazee
SEED_ADMIN_EMAIL=admin@webamazee.com
SEED_ADMIN_PASSWORD=Admin@12345
